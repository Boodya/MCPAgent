# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
# NVIDIA NIM
NVIDIA_API_KEY=
MCPAGENT_APP_DIR=.example-project
# Logging (DEBUG, INFO, WARNING)
MCPAGENT_LOG_LEVEL=WARNING

# Application directory — self-contained folder with config.yaml, mcp.json,
# skills/, agents/, workflows/ and all data.  When set, all relative paths
# in config.yaml resolve from this directory.
# MCPAGENT_APP_DIR=.local-assistants

# Override only the config directory (legacy, ignored when APP_DIR is set)
# MCPAGENT_CONFIG_DIR=config
